{
	"name": "@buildinams/lint",
	"description": "BiA's base lint config(s).",
	"version": "1.0.1",
	"license": "MIT",
	"author": "Build in Amsterdam <development@buildinamsterdam.com> (https://www.buildinamsterdam.com/)",
	"exports": {
		"./eslint/javascript": {
			"import": "./eslint/javascript.mjs",
			"require": "./eslint/javascript.js"
		},
		"./eslint/typescript": {
			"import": "./eslint/typescript.mjs",
			"require": "./eslint/typescript.js"
		},
		"./eslint/react": {
			"import": "./eslint/react-javascript.mjs",
			"require": "./eslint/react-javascript.js"
		},
		"./eslint/react-typescript": {
			"import": "./eslint/react-typescript.mjs",
			"require": "./eslint/react-typescript.js"
		},
		"./eslint/next": {
			"import": "./eslint/next-javascript.mjs",
			"require": "./eslint/next-javascript.js"
		},
		"./eslint/next-typescript": {
			"import": "./eslint/next-typescript.mjs",
			"require": "./eslint/next-typescript.js"
		},
		"./stylelint": {
			"import": "./stylelint/index.mjs",
			"require": "./stylelint/index.js"
		},
		"./prettier": {
			"import": "./prettier/index.mjs",
			"require": "./prettier/index.js"
		}
	},
	"homepage": "https://github.com/buildinamsterdam/lint#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/buildinamsterdam/lint.git"
	},
	"bugs": {
		"url": "https://github.com/buildinamsterdam/lint/issues"
	},
	"keywords": [
		"bia",
		"lint",
		"eslint",
		"prettier"
	],
	"engines": {
		"node": ">=20.19.0"
	},
	"scripts": {
		"lint": "eslint \"**/*.js\"",
		"prettier": "prettier --check --ignore-unknown .",
		"prettier:fix": "prettier --write --ignore-unknown .",
		"depcheck": "npx npm-check --update"
	},
	"peerDependencies": {
		"eslint": ">=9.0.0 <11",
		"prettier": ">=3.0.0",
		"react": ">=17.0.0 || 18 || 19",
		"stylelint": ">=16.0.0",
		"typescript": ">=5.1.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"typescript": {
			"optional": true
		},
		"prettier": {
			"optional": true
		},
		"stylelint": {
			"optional": true
		}
	},
	"devDependencies": {
		"eslint": "^9.0.0",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@next/eslint-plugin-next": "^16.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import-x": "^4.6.1",
		"eslint-plugin-jsx-a11y": "^6.10.0",
		"eslint-plugin-prettier": "^5.2.0",
		"eslint-plugin-react": "^7.37.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-simple-import-sort": "^12.0.0",
		"eslint-plugin-unused-imports": "^4.0.0",
		"globals": "^15.0.0",
		"prettier": "^3.1.1",
		"stylelint-config-css-modules": "^4.4.0",
		"stylelint-config-recess-order": "^4.4.0",
		"stylelint-config-standard-scss": "^13.0.0",
		"stylelint-declaration-block-no-ignored-properties": "^2.8.0",
		"stylelint-order": "^6.0.4",
		"stylelint-prettier": "^5.0.0",
		"typescript-eslint": "^8.0.0"
	}
}
